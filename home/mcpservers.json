{
  "mcpServers": {
    "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "command": "uvx"
    },
    "filesystem": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/"
      ],
      "autoApprove": [
        "search_files"
      ],
      "command": "npx",
      "disabled": false
    },
    "memory": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "command": "npx"
    },
    "playwright": {
      "args": [
        "-y",
        "@executeautomation/playwright-mcp-server"
      ],
      "command": "npx"
    },
    "sequentialthinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "command": "npx"
    },
    "time": {
      "args": [
        "mcp-server-time",
        "--local-timezone",
        "America/Los_Angeles"
      ],
      "autoApprove": [
        "get_current_time",
        "convert_time"
      ],
      "command": "uvx",
      "disabled": false
    }
  },
  "nativeMCPServers": []
}
